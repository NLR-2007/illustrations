# ExplainDraw Configuration

# Image Generation Provider: manual | openai-compatible | custom-http
IMAGE_PROVIDER=manual

# OpenAI/OpenAI-compatible Settings (Only required if provider is openai-compatible)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
# Image model to use (e.g., dall-e-3)
IMAGE_MODEL=dall-e-3

# Custom HTTP API Settings (Only required if provider is custom-http)
CUSTOM_HTTP_URL=
CUSTOM_HTTP_HEADERS={"Authorization": "Bearer YOUR_TOKEN", "Content-Type": "application/json"}
